---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { site } from '../../lib/site';

const locations = (await getCollection('locations')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`Service Areas | ${site.name}`}
  description={`Appliance repair across the Las Vegas metro: ${site.serviceAreaCities.join(', ')}.`}
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Locations', url: '/locations/' }]} />

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Service Areas</h1>
    <p class="mt-3 max-w-2xl text-slate-600">
      We provide same-day and next-day appliance repair across {locations.length} areas of the Las Vegas metro,
      covering {locations.reduce((sum, l) => sum + l.data.zipCodes.length, 0)}+ ZIP codes.
    </p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {locations.map((location) => (
        <a
          href={`/locations/${location.id}/`}
          class="block rounded-lg border border-slate-200 p-6 transition hover:border-blue-300 hover:shadow-md"
        >
          <h2 class="text-lg font-semibold text-slate-900">{location.data.name}</h2>
          <p class="mt-2 text-xs text-slate-500">ZIP codes: {location.data.zipCodes.join(', ')}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-blue-700">Service in {location.data.name} &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
