---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { site } from '../../lib/site';
import { breadcrumbSchema, locationServiceSchema, faqSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Locations', url: '/locations/' },
  { name: entry.data.name, url: `/locations/${entry.id}/` },
];

const pageUrl = new URL(`/locations/${entry.id}/`, Astro.site).toString();

const faq = faqSchema([
  {
    question: `How fast can you get a technician to ${entry.data.name}?`,
    answer: `Same-day and next-day appointments are available throughout ${entry.data.name}. ${site.serviceCallFee} service call, waived when you move forward with the repair.`,
  },
  {
    question: `What ZIP codes do you cover in ${entry.data.name}?`,
    answer: `We serve ${entry.data.zipCodes.join(', ')} and the surrounding area.`,
  },
  {
    question: `What appliances do you repair in ${entry.data.name}?`,
    answer: 'Washers, dryers, refrigerators, dishwashers, ovens, ranges, microwaves, and garbage disposals, from everyday brands to premium built-in kitchen makers.',
  },
]);
---

<Layout
  title={`Appliance Repair in ${entry.data.name}, NV | ${site.name}`}
  description={entry.data.metaDescription}
  schema={[
    breadcrumbSchema(breadcrumbItems.map((i) => ({ ...i, url: new URL(i.url, Astro.site).toString() }))),
    locationServiceSchema({ city: entry.data.name, description: entry.data.metaDescription, url: pageUrl, lat: entry.data.lat, lng: entry.data.lng }),
    faq,
  ]}
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl lg:text-5xl dark:text-white">Appliance Repair in {entry.data.name}, NV</h1>

    <div class="prose prose-slate mt-8 max-w-none dark:prose-invert">
      <Content />
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Neighborhoods we serve in {entry.data.name}</h2>
      <p class="mt-3 flex flex-wrap gap-2 text-sm text-slate-600 dark:text-slate-400">
        {entry.data.neighborhoods.map((n) => (
          <span class="rounded-md border border-slate-200 px-2.5 py-1 dark:border-slate-800">{n}</span>
        ))}
      </p>
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">ZIP codes we serve in {entry.data.name}</h2>
      <p class="mt-3 flex flex-wrap gap-2 text-sm text-slate-600 dark:text-slate-400">
        {entry.data.zipCodes.map((zip) => (
          <span class="rounded-md border border-slate-200 px-2.5 py-1 font-mono dark:border-slate-800">{zip}</span>
        ))}
      </p>
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">What we repair in {entry.data.name}</h2>
      <p class="mt-3 flex flex-wrap gap-2 text-sm text-slate-600 dark:text-slate-400">
        {['Washers', 'Dryers', 'Refrigerators', 'Dishwashers', 'Ovens & Ranges', 'Microwaves', 'Garbage Disposals'].map((label, i) => {
          const hrefs = [
            '/services/washer-repair/',
            '/services/dryer-repair/',
            '/services/refrigerator-repair/',
            '/services/dishwasher-repair/',
            '/services/oven-range-repair/',
            '/services/microwave-repair/',
            '/services/disposal-repair/',
          ];
          return (
            <a href={hrefs[i]} class="rounded-md border border-slate-200 px-3 py-1 hover:border-blue-300 dark:border-slate-800 dark:hover:border-blue-700">{label}</a>
          );
        })}
      </p>
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Frequently asked questions</h2>
      <div class="mt-4 space-y-4">
        {faq.mainEntity.map((item) => (
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">{item.name}</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{item.acceptedAnswer.text}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Need a technician in {entry.data.name}?</h2>
      <p class="mt-2 text-slate-300">Same-day appointments available. {site.serviceCallFee} service call, waived with repair.</p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <a href={site.phoneHref} class="rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
          Call {site.phoneDisplay}
        </a>
        <button type="button" data-open-booking class="rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
          Request Service
        </button>
      </div>
    </div>
  </article>
</Layout>
