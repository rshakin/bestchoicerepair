---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ApplianceIcon from '../../../components/ApplianceIcon.astro';
import { site } from '../../../lib/site';
import { applianceColor } from '../../../lib/icons';
import { errorCodes, codeSlug } from '../../../lib/errorCodes';
import { breadcrumbSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  return errorCodes.map((appliance) => ({ params: { appliance: appliance.slug }, props: { appliance } }));
}

const { appliance } = Astro.props as { appliance: (typeof errorCodes)[number] };

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Error Codes', url: '/error-codes/' },
  { name: appliance.title, url: `/error-codes/${appliance.slug}/` },
];
---

<Layout
  title={`${appliance.title} Error Codes | ${site.name}`}
  description={`Common ${appliance.title.toLowerCase()} error codes by brand, what they mean, and what typically causes them. Same-day diagnosis and repair in Las Vegas.`}
  schema={breadcrumbSchema(breadcrumbItems.map((i) => ({ ...i, url: new URL(i.url, Astro.site).toString() })))}
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="flex items-center gap-4">
      <span class={`inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-lg ${applianceColor(appliance.slug).bg} ${applianceColor(appliance.slug).text}`}>
        <ApplianceIcon name={appliance.slug} class="h-8 w-8" />
      </span>
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">{appliance.title} Error Codes</h1>
    </div>

    <p class="mt-6 text-slate-600 dark:text-slate-400">
      Tap a code below for what it means, what usually causes it, and a couple of things you can check yourself.
      Codes can vary by model year — if yours doesn't match, call us and we'll pull the exact fault with our
      diagnostic tools.
    </p>

    {appliance.brands.map((brandGroup) => (
      <div class="mt-10">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">{brandGroup.brand}</h2>
        <div class="mt-4 space-y-3">
          {brandGroup.codes.map((entry) => (
            <a
              href={`/error-codes/${appliance.slug}/${brandGroup.brandSlug}-${codeSlug(entry.code)}/`}
              class="block rounded-lg border border-slate-200 p-4 transition hover:border-blue-300 hover:shadow-sm dark:border-slate-800 dark:hover:border-blue-700"
            >
              <p class="font-mono text-sm font-semibold text-blue-700 dark:text-blue-400">{entry.code}</p>
              <p class="mt-1 font-medium text-slate-900 dark:text-white">{entry.meaning}</p>
              <span class="mt-2 inline-block text-sm font-semibold text-blue-700 dark:text-blue-400">What to check &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">{appliance.title} code you can't clear?</h2>
      <p class="mt-2 text-slate-300">
        Same-day diagnosis and repair across Las Vegas, Henderson, and Summerlin. {site.serviceCallFee} service call, waived with repair.
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-4">
        <a href={site.phoneHref} class="inline-block rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
          Call {site.phoneDisplay}
        </a>
        <a href={`/services/${appliance.serviceId}/`} class="inline-block rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
          {appliance.title} Repair Details
        </a>
      </div>
    </div>
  </article>
</Layout>
