---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ApplianceIcon from '../../components/ApplianceIcon.astro';
import { site } from '../../lib/site';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const problems = await getCollection('problems');
  return problems.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const service = await getEntry(entry.data.relatedService);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Problems', url: '/problems/' },
  { name: entry.data.title, url: `/problems/${entry.id}/` },
];

const faq = faqSchema([
  {
    question: `What causes ${entry.data.title.toLowerCase()}?`,
    answer: entry.data.causes.join('; ') + '.',
  },
]);
---

<Layout
  title={`${entry.data.title} — Causes & Repair | ${site.name}`}
  description={entry.data.metaDescription}
  schema={[
    faq,
    breadcrumbSchema(breadcrumbItems.map((i) => ({ ...i, url: new URL(i.url, Astro.site).toString() }))),
  ]}
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <span class="inline-flex rounded-lg bg-blue-50 p-3 text-blue-700">
      <ApplianceIcon name={entry.data.appliance} class="h-8 w-8" />
    </span>
    <h1 class="mt-4 text-3xl font-bold text-slate-900 sm:text-4xl">{entry.data.title}</h1>

    <div class="mt-8">
      <h2 class="text-lg font-semibold text-slate-900">Likely causes</h2>
      <ul class="mt-4 space-y-2">
        {entry.data.causes.map((cause) => (
          <li class="flex items-start gap-2 text-sm text-slate-700">
            <span class="mt-1 text-blue-600">&#10003;</span>
            {cause}
          </li>
        ))}
      </ul>
    </div>

    <div class="prose prose-slate mt-8 max-w-none">
      <Content />
    </div>

    {service && (
      <p class="mt-8 text-sm text-slate-600">
        This is one of the issues covered under our{' '}
        <a href={`/services/${service.id}/`} class="font-semibold text-blue-700 hover:underline">{service.data.title}</a> service.
      </p>
    )}

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Dealing with this issue?</h2>
      <p class="mt-2 text-slate-300">Get a same-day diagnosis from a local technician.</p>
      <a href={site.phoneHref} class="mt-4 inline-block rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
        Call {site.phoneDisplay}
      </a>
    </div>
  </article>
</Layout>
