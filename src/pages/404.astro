---
import Layout from '../layouts/Layout.astro';
import { site } from '../lib/site';
---

<Layout
  title={`Page Not Found | ${site.name}`}
  description="The page you're looking for doesn't exist. Find appliance repair services, service areas, and more."
  noIndex
>
  <section class="mx-auto max-w-2xl px-4 py-20 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">404</p>
    <h1 class="mt-3 text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Page not found</h1>
    <p class="mt-4 text-slate-600 dark:text-slate-400">
      That page doesn't exist or may have moved. Here are a few places to try instead.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="rounded-md bg-blue-700 px-6 py-3 font-semibold text-white hover:bg-blue-800">
        Go Home
      </a>
      <a href="/services/" class="rounded-md border border-slate-300 px-6 py-3 font-semibold text-slate-700 hover:border-blue-300 hover:text-blue-700 dark:border-slate-700 dark:text-slate-300 dark:hover:border-blue-500 dark:hover:text-blue-400">
        Browse Services
      </a>
      <button type="button" data-open-booking class="rounded-md border border-slate-300 px-6 py-3 font-semibold text-slate-700 hover:border-blue-300 hover:text-blue-700 dark:border-slate-700 dark:text-slate-300 dark:hover:border-blue-500 dark:hover:text-blue-400">
        Request Service
      </button>
    </div>

    <p class="mt-8 text-sm text-slate-500 dark:text-slate-500">
      Or call us directly — <a href={site.phoneHref} class="font-semibold text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>
    </p>
  </section>
</Layout>
