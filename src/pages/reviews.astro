---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../lib/site';
import { breadcrumbSchema, reviewSchema } from '../lib/schema';

// Real reviews, copied verbatim from the business's Google profile. Do not
// fabricate reviews or edit a reviewer's wording — see src/lib/schema.ts.
const reviews = [
  {
    author: 'Elon E',
    rating: 5,
    date: '2024-10-19',
    text: "Best Choice Repair is an amazing appliance repair company, I used them multiple time and it always been it always been a great experience. I highly recommend this company for any appliance repair and will definitely use them again.",
  },
  {
    author: 'Anastasia Pawloski',
    rating: 5,
    date: '2024-07-25',
    text: 'Robert took my phone call this morning, as our fridge and freezer were not cooling, and was incredibly personable and swift to help! He was able to work in a time frame that fit our busy schedule and was quick to determine what needed to be replaced and repaired. Very professional and informative, our family is so grateful to have found this company!',
  },
  {
    author: 'Shandi Lamb',
    rating: 5,
    text: 'These guys are amazing. They came out after hours to take care of my refrigerator. Rob and Mike are great guys that earned my trust and business. I called them on Friday night at 8 pm and they came out and fixed my GE on the spot. GREAT Service.',
  },
  {
    author: 'Natilee Prezgay',
    rating: 5,
    text: 'I have never had to call an appliance repair place so I did not know what to expect. We called to get our washer looked at and someone was able to come same day. Sorry to say I do not know the repair man\'s name but he was so nice and took care of everything. I highly recommend this business.',
  },
  {
    author: 'Eugene Belmes',
    rating: 5,
    date: '2020-03-08',
    text: 'Robert came out to my house on the weekend, to repair my Samsung washer machine, diagnosed a bad drain pump. Replaced the drain pump, all is good. Thanks for explaining on how to properly clean the pump and how to drain the water. Great service, wife is happy.',
  },
  {
    author: 'Jacqueline Baldwin',
    rating: 5,
    text: 'Robert was great. He helped diagnose my frig. I got 975.00 from achosa warranty for a new frig. Yay Robert!',
  },
];

const reviewLinks = [
  { label: 'Leave us a Google review', href: site.googleReviewUrl },
  { label: 'Leave us a Yelp review', href: '#' },
];

const schema = [breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews/' }]), ...reviewSchema(reviews)];
---

<Layout
  title={`Reviews | ${site.name}`}
  description="See what customers say about our appliance repair service in Las Vegas, or leave us a review on Google or Yelp."
  schema={schema}
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews/' }]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl lg:text-5xl dark:text-white">Customer Reviews</h1>

    <div class="mt-4 flex items-center gap-2">
      <div class="flex text-amber-400">
        {Array.from({ length: 5 }).map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.5l2.9 6.1 6.6.8-4.9 4.6 1.3 6.6L12 17.4l-5.9 3.2 1.3-6.6-4.9-4.6 6.6-.8L12 2.5z" />
          </svg>
        ))}
      </div>
      <p class="font-semibold text-slate-900 dark:text-white">{site.googleRating} out of 5</p>
      <p class="text-sm text-slate-500 dark:text-slate-400">({site.googleReviewCount} Google reviews)</p>
    </div>

    <p class="mt-4 text-slate-600 dark:text-slate-400">
      We're proud of the work we do for homeowners across the Las Vegas valley. Here's a handful of what customers
      have said on Google — or let us know how we did after your repair.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      {reviewLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md border border-slate-300 px-5 py-3 font-semibold text-slate-700 hover:border-blue-300 hover:text-blue-700 dark:border-slate-700 dark:text-slate-300 dark:hover:border-blue-500 dark:hover:text-blue-400"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {reviews.map((review) => (
        <div class="rounded-lg border border-slate-200 p-5 dark:border-slate-800">
          <div class="flex text-amber-400">
            {Array.from({ length: review.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.5l2.9 6.1 6.6.8-4.9 4.6 1.3 6.6L12 17.4l-5.9 3.2 1.3-6.6-4.9-4.6 6.6-.8L12 2.5z" />
              </svg>
            ))}
          </div>
          <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">{review.text}</p>
          <p class="mt-3 text-sm font-semibold text-slate-900 dark:text-white">{review.author}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Just had a repair with us?</h2>
      <p class="mt-2 text-slate-300">We'd appreciate a review — it helps other Las Vegas homeowners find us.</p>
      <a href={site.phoneHref} class="mt-4 inline-block rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
        Call {site.phoneDisplay}
      </a>
    </div>
  </section>
</Layout>
