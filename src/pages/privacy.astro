---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../lib/site';

const effectiveDate = 'July 24, 2026';
---

<Layout
  title={`Privacy Policy | ${site.name}`}
  description={`Privacy policy for ${site.name}, including how we handle text message (SMS) communications.`}
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Privacy Policy', url: '/privacy/' }]} />

  <section class="mx-auto max-w-3xl px-4 py-12 text-sm text-slate-700 dark:text-slate-300">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Privacy Policy</h1>
    <p class="mt-2 text-slate-500 dark:text-slate-400">Effective {effectiveDate}</p>

    <div class="mt-8 space-y-8">
      <div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Information We Collect</h2>
        <p class="mt-2">
          When you request service from {site.name} — by phone, email, or our website booking form — we collect
          the information needed to schedule and complete your repair: your name, phone number, email address,
          service address, and details about the appliance issue.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">How We Use It</h2>
        <p class="mt-2">
          We use this information to schedule your appointment, dispatch a technician, provide updates about your
          service, and send invoices. We do not sell your information, and we do not share it with third parties
          for their own marketing purposes.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">SMS / Text Messaging Terms</h2>
        <p class="mt-2">
          If you opt in to text updates when booking service, {site.name} may send you text messages related to
          your appointment — confirmations, technician on-the-way alerts, and invoices. We do not send marketing
          or promotional text messages.
        </p>
        <ul class="mt-3 list-disc space-y-1 pl-5">
          <li>Message frequency varies based on your service activity.</li>
          <li>Message and data rates may apply.</li>
          <li>Reply <strong>STOP</strong> at any time to opt out of text messages.</li>
          <li>Reply <strong>HELP</strong> for help, or call us at {site.phoneDisplay}.</li>
          <li>Consent to receive texts is not a condition of purchasing any service.</li>
        </ul>
        <p class="mt-3">
          <strong>No mobile information will be shared with third parties or affiliates for marketing or
          promotional purposes.</strong> Carrier delivery is not guaranteed. Text messaging is not a substitute
          for calling us directly for time-sensitive matters. See our{' '}
          <a href="/terms/" class="text-blue-700 hover:underline dark:text-blue-400">Terms &amp; Conditions</a>{' '}
          for the full text messaging program terms.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Contact Us</h2>
        <p class="mt-2">
          Questions about this policy or your information? Call {site.phoneDisplay} or email{' '}
          <a href={`mailto:${site.email}`} class="text-blue-700 hover:underline dark:text-blue-400">{site.email}</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
