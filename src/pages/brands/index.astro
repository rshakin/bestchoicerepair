---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BrandMark from '../../components/BrandMark.astro';
import { site } from '../../lib/site';

const brands = (await getCollection('brands')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`Brands We Repair | ${site.name}`}
  description="Appliance repair for Samsung, GE, Whirlpool, Maytag, Bosch, Wolf, and Thermador in Las Vegas. Same-day service, 90-day warranty."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }]} />

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Brands We Repair</h1>
    <p class="mt-3 max-w-2xl text-slate-600">
      From everyday brands to premium kitchen makers, our technicians are experienced across the full range of
      appliance manufacturers found in Las Vegas homes.
    </p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((brand) => (
        <a
          href={`/brands/${brand.id}/`}
          class="group block rounded-lg border border-slate-200 p-6 transition hover:border-blue-300 hover:shadow-md"
        >
          <BrandMark name={brand.data.name} class="px-4 py-2 text-sm" />
          <h2 class="mt-4 text-lg font-semibold text-slate-900">{brand.data.name}</h2>
          <span class="mt-4 inline-block text-sm font-semibold text-blue-700">View {brand.data.name} repairs &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
