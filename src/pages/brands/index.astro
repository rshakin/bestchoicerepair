---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BrandMark from '../../components/BrandMark.astro';
import { site } from '../../lib/site';

const brands = (await getCollection('brands')).sort((a, b) => a.data.order - b.data.order);

const tierOrder = ['Luxury & Built-In', 'Modern & Everyday', 'Workhorse & Value'] as const;
const tierCopy: Record<(typeof tierOrder)[number], string> = {
  'Luxury & Built-In': 'Premium and built-in kitchen brands found in Summerlin and Henderson\'s higher-end homes.',
  'Modern & Everyday': 'Common brands in newer builds and remodeled kitchens across the valley.',
  'Workhorse & Value': 'Reliable, widely-owned brands we service on nearly every route.',
};
const brandsByTier = tierOrder.map((tier) => ({
  tier,
  copy: tierCopy[tier],
  brands: brands.filter((b) => b.data.tier === tier),
}));
---

<Layout
  title={`Brands We Repair | ${site.name}`}
  description="Appliance repair for Samsung, GE, Whirlpool, Maytag, Bosch, Wolf, Thermador, Sub-Zero, and Viking in Las Vegas. Same-day service, 90-day warranty."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }]} />

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Brands We Repair</h1>
    <p class="mt-3 max-w-2xl text-slate-600 dark:text-slate-400">
      We carry common parts for {brands.length} brands on every truck, from everyday names to premium built-in
      kitchen makers found in Las Vegas homes.
    </p>

    {brandsByTier.map(({ tier, copy, brands: tierBrands }) => (
      <div class="mt-12 first:mt-8">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">{tier}</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{copy}</p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {tierBrands.map((brand) => (
            <a
              href={`/brands/${brand.id}/`}
              class="group block rounded-lg border border-slate-200 p-6 transition hover:border-blue-300 hover:shadow-md dark:border-slate-800 dark:hover:border-blue-700"
            >
              <BrandMark name={brand.data.name} class="px-4 py-2 text-sm" />
              <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">{brand.data.name}</h3>
              <span class="mt-4 inline-block text-sm font-semibold text-blue-700 dark:text-blue-400">View {brand.data.name} repairs &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <p class="mt-12 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800 dark:text-slate-500">
      {site.name} is independent and family-owned. We are not factory-authorized or affiliated with any of the
      brands listed above. We service these brands because we've invested in the parts inventory, the diagnostic
      tools, and the in-home repair history.
    </p>
  </section>
</Layout>
