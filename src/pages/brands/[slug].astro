---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BrandMark from '../../components/BrandMark.astro';
import { site } from '../../lib/site';
import { breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Brands', url: '/brands/' },
  { name: entry.data.name, url: `/brands/${entry.id}/` },
];
---

<Layout
  title={`${entry.data.name} Appliance Repair in Las Vegas | ${site.name}`}
  description={entry.data.metaDescription}
  schema={breadcrumbSchema(breadcrumbItems.map((i) => ({ ...i, url: new URL(i.url, Astro.site).toString() })))}
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <BrandMark name={entry.data.name} size="lg" />
    <h1 class="mt-4 text-3xl font-bold text-slate-900 sm:text-4xl lg:text-5xl dark:text-white">{entry.data.name} Appliance Repair</h1>

    <div class="prose prose-slate mt-8 max-w-none dark:prose-invert">
      <Content />
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Common {entry.data.name} issues we fix</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {entry.data.commonIssues.map((issue) => (
          <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
            <span class="mt-1 text-blue-600 dark:text-blue-400">&#10003;</span>
            {issue}
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Have a {entry.data.name} that needs a repair?</h2>
      <p class="mt-2 text-slate-300">Same-day service available across Las Vegas, Henderson, and Summerlin.</p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <a href={site.phoneHref} class="rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
          Call {site.phoneDisplay}
        </a>
        <button type="button" data-open-booking class="rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
          Request Service
        </button>
      </div>
    </div>
  </article>
</Layout>
