---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { site } from '../../lib/site';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`Appliance Repair Services | ${site.name}`}
  description="Full appliance repair services in Las Vegas: washers, dryers, refrigerators, dishwashers, ovens, ranges, microwaves, and garbage disposals."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Services', url: '/services/' }]} />

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Appliance Repair Services</h1>
    <p class="mt-3 max-w-2xl text-slate-600">
      Same-day and next-day repair for every major household appliance. {site.serviceCallFee} service call, waived
      with repair, and every job is backed by our {site.warranty}.
    </p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <a
          href={`/services/${service.id}/`}
          class="block rounded-lg border border-slate-200 p-6 transition hover:border-blue-300 hover:shadow-md"
        >
          <h2 class="text-lg font-semibold text-slate-900">{service.data.title}</h2>
          <p class="mt-2 text-sm text-slate-600">{service.data.shortDescription}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-blue-700">Learn more &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
