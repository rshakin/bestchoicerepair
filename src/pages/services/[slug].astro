---
import { getCollection, getEntries, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ApplianceIcon from '../../components/ApplianceIcon.astro';
import BrandMark from '../../components/BrandMark.astro';
import { site, brandSlug } from '../../lib/site';
import { serviceSchema, breadcrumbSchema } from '../../lib/schema';
import { applianceColor, applianceImage } from '../../lib/icons';
import { errorCodes } from '../../lib/errorCodes';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const relatedProblems = entry.data.relatedProblems.length
  ? await getEntries(entry.data.relatedProblems)
  : [];
const locations = (await getCollection('locations')).sort((a, b) => a.data.order - b.data.order);
const pageUrl = new URL(`/services/${entry.id}/`, Astro.site).toString();
const applianceErrorCodes = errorCodes.find((a) => a.slug === entry.data.icon);
const heroImage = applianceImage(entry.data.icon);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services/' },
  { name: entry.data.title, url: `/services/${entry.id}/` },
];
---

<Layout
  title={`${entry.data.title} in Las Vegas | ${site.name}`}
  description={entry.data.metaDescription}
  schema={[
    serviceSchema({ name: entry.data.title, description: entry.data.metaDescription, url: pageUrl }),
    breadcrumbSchema(breadcrumbItems.map((i) => ({ ...i, url: new URL(i.url, Astro.site).toString() }))),
  ]}
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="flex items-center gap-4">
      {heroImage ? (
        <Image src={heroImage} alt={entry.data.title} width={64} height={64} class="h-16 w-16 shrink-0 rounded-lg bg-slate-50 object-cover dark:bg-slate-800" />
      ) : (
        <span class={`inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-lg ${applianceColor(entry.data.icon).bg} ${applianceColor(entry.data.icon).text}`}>
          <ApplianceIcon name={entry.data.icon} class="h-8 w-8" />
        </span>
      )}
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl lg:text-5xl dark:text-white">{entry.data.title} in Las Vegas</h1>
    </div>

    <div class="mt-4 flex flex-wrap gap-3 text-sm">
      <span class="rounded-full bg-blue-50 px-3 py-1 font-medium text-blue-700 dark:bg-blue-950/40 dark:text-blue-400">{site.serviceCallFee} service call, waived with repair</span>
      <span class="rounded-full bg-emerald-50 px-3 py-1 font-medium text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-400">{site.warranty}</span>
      <span class="rounded-full bg-slate-100 px-3 py-1 font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-300">Same-day service available</span>
    </div>

    <div class="prose prose-slate mt-8 max-w-none dark:prose-invert">
      <Content />
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Common {entry.data.title.toLowerCase()} issues we fix</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {entry.data.commonIssues.map((issue) => (
          <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
            <span class="mt-1 text-blue-600 dark:text-blue-400">&#10003;</span>
            {issue}
          </li>
        ))}
      </ul>
    </div>

    {relatedProblems.length > 0 && (
      <div class="mt-10">
        <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Related problems</h2>
        <ul class="mt-4 space-y-2">
          {relatedProblems.map((problem) => (
            <li>
              <a href={`/problems/${problem.id}/`} class="text-blue-700 hover:underline dark:text-blue-400">{problem.data.title}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {applianceErrorCodes && (
      <div class="mt-10 rounded-lg border border-slate-200 p-5 dark:border-slate-800">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Seeing an error code?</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Check what your {entry.data.title.toLowerCase()}'s display code means before you call.
        </p>
        <a href={`/error-codes/${applianceErrorCodes.slug}/`} class="mt-3 inline-block text-sm font-semibold text-blue-700 hover:underline dark:text-blue-400">
          View {entry.data.title} error codes &rarr;
        </a>
      </div>
    )}

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Brands we service</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {site.brandsShort.map((brand) => (
          <a href={`/brands/${brandSlug(brand)}/`} class="group">
            <BrandMark name={brand} size="sm" />
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Areas we serve</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {locations.map((location) => (
          <a href={`/locations/${location.id}/`} class="rounded-md border border-slate-200 px-3 py-1 text-sm text-slate-700 hover:border-blue-300 dark:border-slate-800 dark:text-slate-300 dark:hover:border-blue-700">
            {location.data.name}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-12 rounded-lg bg-slate-900 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Need {entry.data.title.toLowerCase()} today?</h2>
      <p class="mt-2 text-slate-300">Call now for same-day service across Las Vegas, Henderson, and Summerlin.</p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <a href={site.phoneHref} class="rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
          Call {site.phoneDisplay}
        </a>
        <button type="button" data-open-booking class="rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
          Request Service
        </button>
      </div>
    </div>
  </article>
</Layout>
