---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ApplianceIcon from '../components/ApplianceIcon.astro';
import BrandMark from '../components/BrandMark.astro';
import { site, brandSlug } from '../lib/site';
import { applianceColor, applianceImage } from '../lib/icons';
import heroTechnician from '../assets/hero-technician.png';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const locations = (await getCollection('locations')).sort((a, b) => a.data.order - b.data.order);
const featuredProblemIds = ['refrigerator-not-cooling', 'washer-wont-drain', 'dryer-not-heating', 'oven-not-heating'];
const allProblems = await getCollection('problems');
const featuredProblems = featuredProblemIds
  .map((id) => allProblems.find((p) => p.id === id))
  .filter((p) => p !== undefined);
---

<Layout
  title={`Appliance Repair in Las Vegas | ${site.name}`}
  description="Same-day washer, dryer, refrigerator, dishwasher, oven & microwave repair in Las Vegas, Henderson & Summerlin. $89 service call, 90-day warranty."
>
  <section class="bg-slate-900">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 sm:py-24 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-400">Las Vegas Appliance Repair</p>
        <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Same-day appliance repair, done right the first time.</h1>
        <p class="mt-4 text-lg text-slate-300">{site.tagline}</p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href={site.phoneHref} class="rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
            Call {site.phoneDisplay}
          </a>
          <button type="button" data-open-booking class="rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
            Request Service
          </button>
        </div>

        <dl class="mt-10 grid grid-cols-2 gap-4 text-sm text-slate-300 sm:grid-cols-3">
          <div>
            <dt class="font-semibold text-white">{site.serviceCallFee}</dt>
            <dd>Service call, waived with repair</dd>
          </div>
          <div>
            <dt class="font-semibold text-white">90 days</dt>
            <dd>Warranty on parts & labor</dd>
          </div>
          <div>
            <dt class="font-semibold text-white">24 hrs</dt>
            <dd>Emergency service available</dd>
          </div>
        </dl>
      </div>

      <div>
        <div class="overflow-hidden rounded-xl border border-slate-700">
          <Image
            src={heroTechnician}
            alt="Best Choice Repair technician servicing a washing machine"
            class="w-full object-cover"
          />
        </div>

        <div class="mt-4 rounded-xl border border-slate-700 bg-slate-800/50 p-6">
          <h2 class="text-lg font-semibold text-white">Hours</h2>
          <ul class="mt-3 space-y-1 text-sm text-slate-300">
            {site.hours.map((h) => (
              <li class="flex justify-between border-b border-slate-700/50 py-2">
                <span>{h.days}</span>
                <span class="font-medium text-white">{h.time}</span>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-sm text-slate-400">Serving {site.serviceAreaCities.join(', ')}.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">Appliances We Repair</h2>
      <a href="/services/" class="text-sm font-semibold text-blue-700 hover:underline dark:text-blue-400">View all services &rarr;</a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => {
        const img = applianceImage(service.data.icon);
        return (
        <a
          href={`/services/${service.id}/`}
          class="block rounded-lg border border-slate-200 p-5 transition hover:border-blue-300 hover:shadow-md dark:border-slate-800 dark:hover:border-blue-700"
        >
          {img ? (
            <Image src={img} alt={service.data.title} width={48} height={48} class="h-12 w-12 rounded-lg bg-slate-50 object-cover dark:bg-slate-800" loading="lazy" />
          ) : (
            <span class={`inline-flex h-12 w-12 items-center justify-center rounded-lg ${applianceColor(service.data.icon).bg} ${applianceColor(service.data.icon).text}`}>
              <ApplianceIcon name={service.data.icon} />
            </span>
          )}
          <h3 class="mt-3 font-semibold text-slate-900 dark:text-white">{service.data.title}</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{service.data.shortDescription}</p>
        </a>
        );
      })}
    </div>
  </section>

  <section class="border-y border-slate-100 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="flex items-end justify-between">
        <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">Common Problems We Fix</h2>
        <a href="/problems/" class="text-sm font-semibold text-blue-700 hover:underline dark:text-blue-400">See all problems &rarr;</a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {featuredProblems.map((problem) => (
          <a
            href={`/problems/${problem.id}/`}
            class="block rounded-lg bg-white p-5 shadow-sm transition hover:shadow-md dark:bg-slate-900 dark:shadow-none dark:ring-1 dark:ring-slate-800"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">{problem.data.title}</h3>
            <span class="mt-2 inline-block text-sm font-semibold text-blue-700 dark:text-blue-400">See causes &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">Brands We Service</h2>
    <p class="mt-3 max-w-2xl text-slate-600 dark:text-slate-400">
      From everyday brands to premium kitchen makers found in Summerlin and Henderson homes.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      {site.brandsShort.map((brand) => (
        <a href={`/brands/${brandSlug(brand)}/`} class="group">
          <BrandMark name={brand} />
        </a>
      ))}
    </div>
  </section>

  <section class="border-y border-slate-100 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">Serving the Las Vegas Valley</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {locations.map((location) => (
          <a
            href={`/locations/${location.id}/`}
            class="block rounded-lg bg-white p-5 shadow-sm transition hover:shadow-md dark:bg-slate-900 dark:shadow-none dark:ring-1 dark:ring-slate-800"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">{location.data.name}</h3>
            <span class="mt-2 inline-block text-sm font-semibold text-blue-700 dark:text-blue-400">Service details &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="rounded-xl bg-slate-900 px-6 py-12 text-center sm:px-12">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Ready to schedule a repair?</h2>
      <p class="mt-3 text-slate-300">Call now or send a request — we'll get back to you same-day.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href={site.phoneHref} class="rounded-md bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500">
          Call {site.phoneDisplay}
        </a>
        <button type="button" data-open-booking class="rounded-md border border-slate-600 px-6 py-3 font-semibold text-white hover:border-slate-400">
          Request Service
        </button>
      </div>
    </div>
  </section>
</Layout>
