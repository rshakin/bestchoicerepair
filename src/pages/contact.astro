---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../lib/site';
---

<Layout
  title={`Contact Us | ${site.name}`}
  description="Contact Best Choice Repair for appliance repair in Las Vegas. Call, email, or request service online."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact/' }]} />

  <section class="mx-auto grid max-w-5xl gap-10 px-4 py-12 lg:grid-cols-2">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Contact Us</h1>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Call for the fastest response, or send a service request and we'll get back to you same-day.
      </p>

      <dl class="mt-8 space-y-4 text-sm">
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Phone</dt>
          <dd>
            <a href={site.phoneHref} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>
            <span class="text-slate-400 dark:text-slate-600"> / </span>
            <a href={site.phoneHrefLocal} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplayLocal}</a>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Email</dt>
          <dd><a href={`mailto:${site.email}`} class="text-blue-700 hover:underline dark:text-blue-400">{site.email}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Hours</dt>
          <dd>
            <ul class="mt-1 space-y-1 text-slate-600 dark:text-slate-400">
              {site.hours.map((h) => <li>{h.days}: {h.time}</li>)}
            </ul>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Service Area</dt>
          <dd class="text-slate-600 dark:text-slate-400">{site.serviceAreaCities.join(', ')}</dd>
        </div>
      </dl>
    </div>

    <div class="flex flex-col items-center justify-center rounded-lg border border-slate-200 p-8 text-center dark:border-slate-800">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Request service online</h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        Tell us about your appliance and we'll call you back same-day to confirm a time.
      </p>
      <button type="button" data-open-booking class="mt-6 rounded-md bg-blue-700 px-6 py-3 font-semibold text-white hover:bg-blue-800">
        Start Your Request
      </button>
    </div>
  </section>
</Layout>
