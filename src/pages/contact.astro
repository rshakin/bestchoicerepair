---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../lib/site';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`Contact Us | ${site.name}`}
  description="Contact Best Choice Repair for appliance repair in Las Vegas. Call, email, or request service online."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact/' }]} />

  <section class="mx-auto grid max-w-5xl gap-10 px-4 py-12 lg:grid-cols-2">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Contact Us</h1>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Call for the fastest response, or send a service request and we'll get back to you same-day.
      </p>

      <dl class="mt-8 space-y-4 text-sm">
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Phone</dt>
          <dd>
            <a href={site.phoneHref} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>
            <span class="text-slate-400 dark:text-slate-600"> / </span>
            <a href={site.phoneHrefLocal} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplayLocal}</a>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Email</dt>
          <dd><a href={`mailto:${site.email}`} class="text-blue-700 hover:underline dark:text-blue-400">{site.email}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Hours</dt>
          <dd>
            <ul class="mt-1 space-y-1 text-slate-600 dark:text-slate-400">
              {site.hours.map((h) => <li>{h.days}: {h.time}</li>)}
            </ul>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Service Area</dt>
          <dd class="text-slate-600 dark:text-slate-400">{site.serviceAreaCities.join(', ')}</dd>
        </div>
      </dl>
    </div>

    <form id="booking-form" class="relative rounded-lg border border-slate-200 p-6 dark:border-slate-800" novalidate>
      <div id="booking-form-fields" class="grid gap-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Name</label>
            <input type="text" name="name" id="name" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Phone</label>
            <input type="tel" name="phone" id="phone" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
          <input type="email" name="email" id="email" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="appliance_type" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Appliance</label>
            <select name="appliance_type" id="appliance_type" required class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white">
              <option value="">Select an appliance&hellip;</option>
              {services.map((service) => (
                <option value={service.data.title}>{service.data.title}</option>
              ))}
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label for="preferred_time" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Preferred time <span class="text-slate-400">(optional)</span></label>
            <input type="text" name="preferred_time" id="preferred_time" placeholder="e.g. Weekday mornings" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
          </div>
        </div>

        <div>
          <label for="address" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Address</label>
          <input type="text" name="address" id="address" placeholder="Street address" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
          <div class="mt-2 grid grid-cols-3 gap-2">
            <input type="text" name="city" placeholder="City" class="rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
            <input type="text" name="state" placeholder="State" value="NV" class="rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
            <input type="text" name="zip" placeholder="ZIP" class="rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
          </div>
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-slate-700 dark:text-slate-300">What's going on?</label>
          <textarea name="description" id="description" rows="4" required placeholder="Describe the issue you're seeing" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white"></textarea>
        </div>

        <input type="text" name="company" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] h-0 w-0 opacity-0" aria-hidden="true" />

        <button type="submit" class="rounded-md bg-blue-700 px-6 py-3 font-semibold text-white hover:bg-blue-800">
          Request Service
        </button>
      </div>

      <div id="booking-form-success" class="hidden text-center">
        <p class="text-lg font-semibold text-slate-900 dark:text-white">Request sent!</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">We'll call you back same-day to confirm a time.</p>
      </div>

      <div id="booking-form-error" class="hidden text-center">
        <p class="text-lg font-semibold text-slate-900 dark:text-white">We couldn't send that automatically.</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Please call or text us instead — <a href={site.phoneHref} class="font-semibold text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>.
        </p>
      </div>
    </form>
  </section>
</Layout>

<script define:vars={{ bookingApiUrl: site.bookingApiUrl }}>
  const form = document.getElementById('booking-form');
  const fields = document.getElementById('booking-form-fields');
  const successEl = document.getElementById('booking-form-success');
  const errorEl = document.getElementById('booking-form-error');

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!bookingApiUrl) {
      fields.classList.add('hidden');
      errorEl.classList.remove('hidden');
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.textContent = 'Sending…';

    try {
      const res = await fetch(bookingApiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error('Request failed');
      fields.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch (e) {
      fields.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }
  });
</script>
