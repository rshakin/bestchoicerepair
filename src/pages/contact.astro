---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../lib/site';

// TODO: GitHub Pages is static and can't process form submissions directly.
// Sign up at https://formspree.io (free tier works fine here), create a
// form, and replace YOUR_FORM_ID below with the real endpoint ID.
const formAction = 'https://formspree.io/f/YOUR_FORM_ID';
---

<Layout
  title={`Contact Us | ${site.name}`}
  description="Contact Best Choice Repair for appliance repair in Las Vegas. Call, email, or request service online."
>
  <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact/' }]} />

  <section class="mx-auto grid max-w-5xl gap-10 px-4 py-12 lg:grid-cols-2">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Contact Us</h1>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Call for the fastest response, or send a service request and we'll get back to you same-day.
      </p>

      <dl class="mt-8 space-y-4 text-sm">
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Phone</dt>
          <dd>
            <a href={site.phoneHref} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>
            <span class="text-slate-400 dark:text-slate-600"> / </span>
            <a href={site.phoneHrefLocal} class="text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplayLocal}</a>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Email</dt>
          <dd><a href={`mailto:${site.email}`} class="text-blue-700 hover:underline dark:text-blue-400">{site.email}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Hours</dt>
          <dd>
            <ul class="mt-1 space-y-1 text-slate-600 dark:text-slate-400">
              {site.hours.map((h) => <li>{h.days}: {h.time}</li>)}
            </ul>
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900 dark:text-white">Service Area</dt>
          <dd class="text-slate-600 dark:text-slate-400">{site.serviceAreaCities.join(', ')}</dd>
        </div>
      </dl>
    </div>

    <form action={formAction} method="POST" class="rounded-lg border border-slate-200 p-6 dark:border-slate-800">
      <div class="grid gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Name</label>
          <input type="text" name="name" id="name" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Phone</label>
          <input type="tel" name="phone" id="phone" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
        </div>
        <div>
          <label for="appliance" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Appliance & Issue</label>
          <input type="text" name="appliance" id="appliance" placeholder="e.g. Refrigerator not cooling" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Message</label>
          <textarea name="message" id="message" rows="4" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-white"></textarea>
        </div>
        <button type="submit" class="rounded-md bg-blue-700 px-6 py-3 font-semibold text-white hover:bg-blue-800">
          Request Service
        </button>
      </div>
    </form>
  </section>
</Layout>
