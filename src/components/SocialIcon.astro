---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'h-4 w-4' } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, '-');
---

{slug === 'yelp' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="currentColor">
    {Array.from({ length: 6 }).map((_, i) => (
      <rect x="10.4" y="1.8" width="3.2" height="7.4" rx="1.6" transform={`rotate(${i * 60} 12 12)`} />
    ))}
  </svg>
)}

{slug === 'facebook' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="currentColor">
    <text x="12" y="17.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="16">f</text>
  </svg>
)}

{slug === 'instagram' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="5" />
    <circle cx="12" cy="12" r="4.2" />
    <circle cx="17.3" cy="6.7" r="0.6" fill="currentColor" stroke="none" />
  </svg>
)}

{slug === 'linkedin' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="currentColor">
    <text x="12" y="16.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="10.5">in</text>
  </svg>
)}

{slug === 'nextdoor' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 11.5 12 4l8 7.5" />
    <path d="M6 10v9h12v-9" />
    <path d="M10 19v-5h4v5" />
  </svg>
)}

{slug === 'houzz' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="currentColor">
    <text x="12" y="17.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="16">H</text>
  </svg>
)}

{slug === 'apple-maps' && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 21s7-7.2 7-12a7 7 0 1 0-14 0c0 4.8 7 12 7 12z" />
    <circle cx="12" cy="9" r="2.4" />
  </svg>
)}
