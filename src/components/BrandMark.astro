---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'px-4 py-2 text-sm' } = Astro.props;
---

<span
  class={`inline-flex items-center justify-center rounded-md border border-slate-200 bg-slate-50 font-bold uppercase tracking-wide text-slate-700 group-hover:border-blue-300 group-hover:text-blue-700 ${className}`}
>
  {name}
</span>
