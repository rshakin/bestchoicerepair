---
interface Props {
  name: string;
  size?: 'sm' | 'md' | 'lg';
}

const { name, size = 'md' } = Astro.props;

// Filler wordmark colors for brands without a licensed logo file yet.
// Badge background is always white (logos need a light background to stay
// legible), so these are fixed colors rather than light/dark variants.
const colors: Record<string, string> = {
  samsung: 'text-blue-600',
  bosch: 'text-red-600',
  lg: 'text-pink-700',
};

const logos: Record<string, string> = {
  ge: '/brands/ge.svg',
  whirlpool: '/brands/whirlpool.svg',
  maytag: '/brands/maytag.png',
  thermador: '/brands/thermador.svg',
  viking: '/brands/viking.svg',
  'sub-zero': '/brands/sub-zero.png',
  wolf: '/brands/wolf.png',
};

const slug = name.toLowerCase().replace(/\s+/g, '-');
const logo = logos[slug];
const color = colors[slug] ?? 'text-slate-700 dark:text-slate-300';

// Every badge is the same fixed box regardless of content — logos scale to
// fit via object-contain, text is a single size — so a grid of mixed
// logos/wordmarks lines up instead of each badge sizing to its own content.
const boxSizes: Record<string, string> = { sm: 'h-10 w-24', md: 'h-14 w-28', lg: 'h-16 w-36' };
const textSizes: Record<string, string> = { sm: 'text-xs', md: 'text-sm', lg: 'text-base' };
const box = boxSizes[size];
const textSize = textSizes[size];
---

<span
  class={`inline-flex shrink-0 items-center justify-center rounded-md border border-slate-200 bg-white p-2 group-hover:border-slate-300 group-hover:shadow-sm dark:border-slate-700 dark:bg-white ${box}`}
>
  {logo ? (
    <img src={logo} alt={name} class="max-h-full max-w-full object-contain" />
  ) : (
    <span class={`whitespace-nowrap font-bold uppercase tracking-wide ${textSize} ${color}`}>{name}</span>
  )}
</span>
