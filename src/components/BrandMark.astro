---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'px-4 py-2 text-sm' } = Astro.props;

// Filler wordmark colors for brands without a licensed logo file yet.
// Badge background is always white (logos need a light background to stay
// legible), so these are fixed colors rather than light/dark variants.
const colors: Record<string, string> = {
  samsung: 'text-blue-600',
  bosch: 'text-red-600',
  lg: 'text-pink-700',
};

const logos: Record<string, string> = {
  ge: '/brands/ge.svg',
  whirlpool: '/brands/whirlpool.svg',
  maytag: '/brands/maytag.svg',
  thermador: '/brands/thermador.svg',
  viking: '/brands/viking.svg',
  'sub-zero': '/brands/sub-zero.png',
  wolf: '/brands/wolf.png',
};

const slug = name.toLowerCase().replace(/\s+/g, '-');
const logo = logos[slug];
const color = colors[slug] ?? 'text-slate-700 dark:text-slate-300';

const logoHeight = className.includes('text-xs') ? 'h-4' : className.includes('text-base') ? 'h-6' : 'h-5';
---

<span
  class={`inline-flex items-center justify-center rounded-md border border-slate-200 bg-white group-hover:border-slate-300 group-hover:shadow-sm dark:border-slate-700 dark:bg-white ${className}`}
>
  {logo ? (
    <img src={logo} alt={name} class={`${logoHeight} w-auto object-contain`} />
  ) : (
    <span class={`font-bold uppercase tracking-wide ${color}`}>{name}</span>
  )}
</span>
