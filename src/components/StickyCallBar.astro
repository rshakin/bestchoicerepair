---
import { site } from '../lib/site';
---

<div class="fixed inset-x-0 bottom-0 z-50 flex border-t border-slate-200 bg-white shadow-[0_-2px_10px_rgba(0,0,0,0.08)] sm:hidden dark:border-slate-800 dark:bg-slate-950">
  <a href={site.phoneHref} class="flex flex-1 items-center justify-center gap-2 bg-blue-700 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] text-sm font-semibold text-white">
    Call {site.phoneDisplay}
  </a>
  <a href={site.smsHref} class="flex flex-1 items-center justify-center gap-2 border-l border-blue-800 bg-blue-800 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] text-sm font-semibold text-white">
    Text Us
  </a>
</div>
