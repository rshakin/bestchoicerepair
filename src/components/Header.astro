---
import { site, navLinks } from '../lib/site';
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 pt-[env(safe-area-inset-top)] backdrop-blur dark:border-slate-800 dark:bg-slate-950/95">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt={site.name} class="h-9 w-auto" width="641" height="527" />
      <span class="flex flex-col leading-tight">
        <span class="text-lg font-bold tracking-tight text-slate-900 dark:text-white">{site.name}</span>
        <span class="hidden text-xs text-slate-500 sm:inline dark:text-slate-400">Las Vegas Appliance Repair</span>
      </span>
    </a>

    <nav class="hidden items-center gap-3 text-[15px] font-medium text-slate-700 xl:flex dark:text-slate-300">
      {navLinks.map((link) => (
        <a href={link.href} class="whitespace-nowrap hover:text-blue-700 dark:hover:text-blue-400">{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        type="button"
        class="inline-flex cursor-pointer items-center justify-center rounded-md border border-slate-300 p-2 text-slate-700 hover:border-blue-300 hover:text-blue-700 dark:border-slate-700 dark:text-slate-300 dark:hover:border-blue-500 dark:hover:text-blue-400"
        aria-label="Toggle dark mode"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.4 6.4-.7-.7M6.3 6.3l-.7-.7m12.8 0-.7.7M6.3 17.7l-.7.7M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
        </svg>
      </button>
      <a
        href={site.phoneHref}
        class="hidden items-center gap-2 rounded-md bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 sm:inline-flex"
      >
        Call {site.phoneDisplay}
      </a>
      <label
        for="nav-toggle"
        class="inline-flex cursor-pointer items-center justify-center rounded-md border border-slate-300 p-2 xl:hidden dark:border-slate-700 dark:text-slate-300"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <input type="checkbox" id="nav-toggle" class="peer hidden" />

  <nav class="hidden flex-col gap-1 border-t border-slate-200 bg-white px-4 py-3 text-base font-medium text-slate-700 peer-checked:flex xl:hidden dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300">
    {navLinks.map((link) => (
      <a href={link.href} class="rounded px-2 py-2.5 hover:bg-slate-50 dark:hover:bg-slate-900">{link.label}</a>
    ))}
    <a href={site.phoneHref} class="mt-2 rounded-md bg-blue-700 px-4 py-2 text-center font-semibold text-white">
      Call {site.phoneDisplay}
    </a>
  </nav>
</header>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
