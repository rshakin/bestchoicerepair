---
import { site, navLinks } from '../lib/site';
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt={site.name} class="h-9 w-auto" width="641" height="527" />
      <span class="flex flex-col leading-tight">
        <span class="text-lg font-bold tracking-tight text-slate-900">{site.name}</span>
        <span class="hidden text-xs text-slate-500 sm:inline">Las Vegas Appliance Repair</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="peer hidden" />

    <nav class="hidden items-center gap-4 text-sm font-medium text-slate-700 xl:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="whitespace-nowrap hover:text-blue-700">{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={site.phoneHref}
        class="hidden items-center gap-2 rounded-md bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 sm:inline-flex"
      >
        Call {site.phoneDisplay}
      </a>
      <label
        for="nav-toggle"
        class="inline-flex cursor-pointer items-center justify-center rounded-md border border-slate-300 p-2 xl:hidden"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <nav class="hidden flex-col gap-1 border-t border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 peer-checked:flex xl:hidden">
    {navLinks.map((link) => (
      <a href={link.href} class="rounded px-2 py-2 hover:bg-slate-50">{link.label}</a>
    ))}
    <a href={site.phoneHref} class="mt-2 rounded-md bg-blue-700 px-4 py-2 text-center font-semibold text-white">
      Call {site.phoneDisplay}
    </a>
  </nav>
</header>
