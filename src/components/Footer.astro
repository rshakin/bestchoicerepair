---
import { site, socialLinks } from '../lib/site';
import SocialIcon from './SocialIcon.astro';

const services = [
  ['Washer Repair', '/services/washer-repair/'],
  ['Dryer Repair', '/services/dryer-repair/'],
  ['Refrigerator Repair', '/services/refrigerator-repair/'],
  ['Dishwasher Repair', '/services/dishwasher-repair/'],
  ['Oven & Range Repair', '/services/oven-range-repair/'],
  ['Microwave Repair', '/services/microwave-repair/'],
  ['Garbage Disposal Repair', '/services/disposal-repair/'],
];

const brands = [
  ['Samsung', '/brands/samsung/'],
  ['GE', '/brands/ge/'],
  ['Whirlpool', '/brands/whirlpool/'],
  ['Maytag', '/brands/maytag/'],
  ['Bosch', '/brands/bosch/'],
  ['LG', '/brands/lg/'],
  ['Wolf', '/brands/wolf/'],
  ['Thermador', '/brands/thermador/'],
  ['Sub-Zero', '/brands/sub-zero/'],
  ['Viking', '/brands/viking/'],
];

const locations = [
  ['Las Vegas', '/locations/las-vegas/'],
  ['Henderson', '/locations/henderson/'],
  ['Paradise', '/locations/paradise/'],
  ['North Las Vegas', '/locations/north-las-vegas/'],
  ['Summerlin', '/locations/summerlin/'],
  ['Green Valley', '/locations/green-valley/'],
  ['Spring Valley', '/locations/spring-valley/'],
  ['Enterprise', '/locations/enterprise/'],
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-900 text-slate-300 dark:border-slate-800">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-5">
    <div class="lg:col-span-2">
      <p class="text-lg font-bold text-white">{site.name}</p>
      <p class="mt-2 text-sm text-slate-400">{site.tagline}</p>
      <p class="mt-4 text-sm">
        <a href={site.phoneHref} class="font-semibold text-white hover:underline">{site.phoneDisplay}</a>
        <span class="text-slate-500"> / </span>
        <a href={site.phoneHrefLocal} class="font-semibold text-white hover:underline">{site.phoneDisplayLocal}</a>
      </p>
      <p class="mt-1 text-sm">
        <a href={`mailto:${site.email}`} class="hover:underline">{site.email}</a>
      </p>
      <ul class="mt-4 space-y-1 text-sm text-slate-400">
        {site.hours.map((h) => (
          <li>{h.days}: <span class="text-slate-300">{h.time}</span></li>
        ))}
      </ul>

      <div class="mt-6 inline-flex rounded-lg border border-slate-700 bg-slate-800/50 p-3">
        <img
          src="/badges/expertise-2026.png"
          alt="Expertise.com: Best Home Appliance Repair Services in Las Vegas, 2026"
          class="h-24 w-auto"
          loading="lazy"
        />
      </div>

      <div class="mt-4 flex max-w-xs flex-wrap gap-2">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-800/50 px-4 py-2.5 text-sm font-medium text-slate-200 transition hover:border-blue-500 hover:bg-slate-800 hover:text-white"
          >
            <SocialIcon name={link.icon} class="h-5 w-5 text-blue-400" />
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-400">Services</p>
      <ul class="mt-3 space-y-2 text-sm">
        {services.map(([label, href]) => (
          <li><a href={href} class="hover:text-white">{label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-400">Brands</p>
      <ul class="mt-3 space-y-2 text-sm">
        {brands.map(([label, href]) => (
          <li><a href={href} class="hover:text-white">{label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-400">Service Areas</p>
      <ul class="mt-3 space-y-2 text-sm">
        {locations.map(([label, href]) => (
          <li><a href={href} class="hover:text-white">{label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-4 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {currentYear} {site.name}. All rights reserved.</p>
      <p>Licensed & insured &middot; {site.warranty}</p>
    </div>
  </div>
</footer>
