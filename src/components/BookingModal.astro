---
import { getCollection } from 'astro:content';
import ApplianceIcon from './ApplianceIcon.astro';
import { site } from '../lib/site';
import { applianceColor, applianceShortName } from '../lib/icons';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<div id="booking-overlay" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/70 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] backdrop-blur-sm">
  <div id="booking-panel" class="flex max-h-[90vh] w-full max-w-lg flex-col overflow-hidden rounded-2xl bg-white shadow-2xl dark:bg-slate-900">
    <div class="flex items-center gap-4 px-6 pt-6">
      <div class="flex flex-1 gap-1.5">
        {[0, 1, 2, 3].map((i) => (
          <span data-progress-dot class="h-1.5 flex-1 rounded-full bg-slate-200 transition-colors dark:bg-slate-700"></span>
        ))}
      </div>
      <button
        type="button"
        id="booking-close"
        aria-label="Close booking form"
        class="-m-2 flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-700 dark:hover:bg-slate-800 dark:hover:text-slate-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="booking-form" class="flex flex-1 flex-col overflow-y-auto px-6 pb-6 pt-4 [-webkit-overflow-scrolling:touch]" novalidate>
      <!-- Step 0: appliance -->
      <div data-step="0" class="booking-step">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">What needs a repair?</h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Pick the appliance giving you trouble.</p>
        <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {services.map((service) => (
            <button
              type="button"
              data-appliance-option
              data-value={service.data.title}
              data-short-label={applianceShortName(service.data.icon)}
              class="flex flex-col items-center gap-2 rounded-xl border-2 border-slate-200 p-4 text-center transition hover:border-blue-300 dark:border-slate-700 dark:hover:border-blue-600"
            >
              <span class={`inline-flex h-10 w-10 items-center justify-center rounded-lg ${applianceColor(service.data.icon).bg} ${applianceColor(service.data.icon).text}`}>
                <ApplianceIcon name={service.data.icon} class="h-5 w-5" />
              </span>
              <span class="text-xs font-medium text-slate-900 dark:text-white">{service.data.title}</span>
            </button>
          ))}
          <button
            type="button"
            data-appliance-option
            data-value="Other"
            data-short-label="appliance"
            class="flex flex-col items-center gap-2 rounded-xl border-2 border-slate-200 p-4 text-center transition hover:border-blue-300 dark:border-slate-700 dark:hover:border-blue-600"
          >
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
              </svg>
            </span>
            <span class="text-xs font-medium text-slate-900 dark:text-white">Something else</span>
          </button>
        </div>
        <input type="hidden" name="appliance_type" id="appliance_type" required />
      </div>

      <!-- Step 1: issue + timing -->
      <div data-step="1" class="booking-step hidden">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">What's going on with your <span data-appliance-label>appliance</span>?</h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">A quick description helps us bring the right parts.</p>
        <textarea
          name="description"
          id="description"
          required
          rows="4"
          placeholder="e.g. Making a loud grinding noise and won't drain"
          class="mt-5 w-full rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white"
        ></textarea>
        <label for="preferred_time" class="mt-4 block text-sm font-medium text-slate-700 dark:text-slate-300">
          Preferred time <span class="font-normal text-slate-400">(optional)</span>
        </label>
        <input
          type="text"
          name="preferred_time"
          id="preferred_time"
          placeholder="e.g. Weekday mornings"
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white"
        />
      </div>

      <!-- Step 2: contact + address -->
      <div data-step="2" class="booking-step hidden">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Where should we send a technician?</h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">We'll call to confirm a same-day or next-day time.</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <input type="text" name="name" id="name" required placeholder="Name" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
          <input type="tel" name="phone" id="phone" required placeholder="Phone" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
        </div>
        <input type="email" name="email" id="email" required placeholder="Email" class="mt-3 w-full rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
        <div class="mt-3 grid grid-cols-3 gap-3">
          <input type="text" name="address" id="address" required placeholder="Street address" class="col-span-2 rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
          <input type="text" name="unit_number" id="unit_number" placeholder="Unit #" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
        </div>
        <div class="mt-3 grid grid-cols-3 gap-3">
          <input type="text" name="city" placeholder="City" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
          <input type="text" name="state" value="NV" placeholder="State" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
          <input type="text" name="zip" placeholder="ZIP" class="rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
        </div>
        <input
          type="text"
          name="gate_code"
          id="gate_code"
          placeholder="Gate code (optional)"
          class="mt-3 w-full rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white"
        />
        <textarea
          name="special_instructions"
          id="special_instructions"
          rows="2"
          placeholder="Special instructions (optional) — e.g. parking, pets, entry notes"
          class="mt-3 w-full rounded-lg border border-slate-300 px-3 py-2 text-base sm:text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-white"
        ></textarea>
        <input type="text" name="company" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] h-0 w-0 opacity-0" aria-hidden="true" />
      </div>

      <!-- Step 3: review -->
      <div data-step="3" class="booking-step hidden">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Review your request</h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Everything look right?</p>
        <dl id="booking-review" class="mt-5 space-y-3 rounded-lg border border-slate-200 p-4 text-sm dark:border-slate-800"></dl>
        <div class="mt-4 flex flex-wrap gap-3 text-xs">
          <span class="rounded-full bg-blue-50 px-3 py-1 font-medium text-blue-700 dark:bg-blue-950/40 dark:text-blue-400">{site.serviceCallFee} service call, waived with repair</span>
          <span class="rounded-full bg-emerald-50 px-3 py-1 font-medium text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-400">{site.warranty}</span>
        </div>
      </div>

      <!-- Success / error -->
      <div data-step="success" class="booking-step hidden text-center">
        <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
          </svg>
        </span>
        <h2 class="mt-4 text-xl font-bold text-slate-900 dark:text-white">Thanks<span data-success-name></span>!</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Your request is in — we'll call you back same-day to confirm a time.</p>
        <button type="button" data-success-done class="mt-6 w-full rounded-lg bg-blue-700 px-6 py-2.5 text-sm font-semibold text-white hover:bg-blue-800">
          Done
        </button>
      </div>
      <div data-step="error" class="booking-step hidden text-center">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">We couldn't send that automatically.</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Please call or text us instead — <a href={site.phoneHref} class="font-semibold text-blue-700 hover:underline dark:text-blue-400">{site.phoneDisplay}</a>.
        </p>
      </div>

      <div id="booking-nav" class="mt-6 flex items-center justify-between gap-3">
        <button type="button" id="booking-back" class="hidden text-sm font-semibold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200">
          &larr; Back
        </button>
        <div class="flex-1"></div>
        <button type="button" id="booking-next" disabled class="rounded-lg bg-blue-700 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-800 disabled:cursor-not-allowed disabled:bg-slate-300 dark:disabled:bg-slate-700">
          Continue
        </button>
        <button type="submit" id="booking-submit" class="hidden rounded-lg bg-blue-700 px-6 py-2.5 text-sm font-semibold text-white hover:bg-blue-800">
          Submit Request
        </button>
      </div>
    </form>
  </div>
</div>

<script define:vars={{ bookingApiUrl: site.bookingApiUrl }}>
  const overlay = document.getElementById('booking-overlay');
  const panel = document.getElementById('booking-panel');
  const form = document.getElementById('booking-form');
  const steps = Array.from(form.querySelectorAll('.booking-step'));
  const dots = Array.from(document.querySelectorAll('[data-progress-dot]'));
  const backBtn = document.getElementById('booking-back');
  const nextBtn = document.getElementById('booking-next');
  const submitBtn = document.getElementById('booking-submit');
  const applianceInput = document.getElementById('appliance_type');
  const applianceLabels = document.querySelectorAll('[data-appliance-label]');
  const closeBtn = document.getElementById('booking-close');
  const successNameEl = document.querySelector('[data-success-name]');
  const successDoneBtn = document.querySelector('[data-success-done]');

  const STEP_COUNT = 4; // steps 0-3 are the real wizard; success/error are terminal
  let current = 0;

  function showStep(name) {
    steps.forEach((el) => {
      el.classList.toggle('hidden', el.dataset.step !== String(name));
    });
  }

  function updateChrome() {
    const inWizard = typeof current === 'number';
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-blue-600', inWizard && i <= current);
      dot.classList.toggle('dark:bg-blue-500', inWizard && i <= current);
      dot.classList.toggle('bg-slate-200', !(inWizard && i <= current));
      dot.classList.toggle('dark:bg-slate-700', !(inWizard && i <= current));
    });
    document.getElementById('booking-nav').classList.toggle('hidden', !inWizard);
    backBtn.classList.toggle('hidden', !inWizard || current === 0);
    nextBtn.classList.toggle('hidden', !inWizard || current === STEP_COUNT - 1);
    submitBtn.classList.toggle('hidden', !inWizard || current !== STEP_COUNT - 1);
    // The success screen has its own "Done" button as the clear way out —
    // the small x in the corner is easy to miss as the primary action.
    closeBtn.classList.toggle('hidden', current === 'success');
  }

  function validateStep() {
    if (current === 0) return !!applianceInput.value;
    if (current === 1) return !!document.getElementById('description').value.trim();
    if (current === 2) {
      return !!(
        document.getElementById('name').value.trim() &&
        document.getElementById('phone').value.trim() &&
        document.getElementById('email').value.trim() &&
        document.getElementById('address').value.trim()
      );
    }
    return true;
  }

  function refreshNextState() {
    nextBtn.disabled = !validateStep();
  }

  function buildReview() {
    const data = Object.fromEntries(new FormData(form).entries());
    const rows = [
      ['Appliance', data.appliance_type],
      ['Issue', data.description],
      ['Preferred time', data.preferred_time || '—'],
      ['Name', data.name],
      ['Phone', data.phone],
      ['Email', data.email],
      ['Address', [data.address, data.unit_number ? `Unit ${data.unit_number}` : '', data.city, data.state, data.zip].filter(Boolean).join(', ')],
    ];
    if (data.gate_code) rows.push(['Gate code', data.gate_code]);
    if (data.special_instructions) rows.push(['Special instructions', data.special_instructions]);
    document.getElementById('booking-review').innerHTML = rows.map(([label, value]) => `
      <div class="flex justify-between gap-4">
        <dt class="text-slate-500 dark:text-slate-400">${label}</dt>
        <dd class="text-right font-medium text-slate-900 dark:text-white">${(value || '').toString().replace(/</g, '&lt;')}</dd>
      </div>
    `).join('');
  }

  function goTo(step) {
    current = step;
    showStep(step);
    if (step === STEP_COUNT - 1) buildReview();
    updateChrome();
    refreshNextState();
    panel.scrollTop = 0;
  }

  document.querySelectorAll('[data-appliance-option]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applianceInput.value = btn.dataset.value;
      applianceLabels.forEach((el) => { el.textContent = btn.dataset.shortLabel; });
      document.querySelectorAll('[data-appliance-option]').forEach((b) => b.classList.remove('border-blue-600', 'bg-blue-50', 'dark:bg-blue-950/30'));
      btn.classList.add('border-blue-600', 'bg-blue-50', 'dark:bg-blue-950/30');
      goTo(1);
    });
  });

  form.addEventListener('input', refreshNextState);

  nextBtn.addEventListener('click', () => {
    if (!validateStep()) return;
    goTo(Math.min(current + 1, STEP_COUNT - 1));
  });
  backBtn.addEventListener('click', () => {
    goTo(Math.max(current - 1, 0));
  });

  function resetForm() {
    form.reset();
    document.querySelectorAll('[data-appliance-option]').forEach((b) => b.classList.remove('border-blue-600', 'bg-blue-50', 'dark:bg-blue-950/30'));
    goTo(0);
  }

  function open() {
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.classList.add('overflow-hidden');
  }
  function close() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
    setTimeout(resetForm, 200);
  }

  closeBtn.addEventListener('click', close);
  successDoneBtn.addEventListener('click', close);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !overlay.classList.contains('hidden')) close(); });
  document.addEventListener('click', (e) => {
    const trigger = e.target.closest('[data-open-booking]');
    if (trigger) { e.preventDefault(); open(); }
  });

  window.openBookingModal = open;
  window.closeBookingModal = close;

  if (new URLSearchParams(window.location.search).has('booking')) {
    open();
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (event.submitter !== submitBtn) return;

    if (!bookingApiUrl) {
      showStep('error');
      current = 'error';
      updateChrome();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(bookingApiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error('Request failed');
      const firstName = (data.name || '').trim().split(/\s+/)[0];
      successNameEl.textContent = firstName ? `, ${firstName}` : '';
      showStep('success');
      current = 'success';
      updateChrome();
    } catch (e) {
      showStep('error');
      current = 'error';
      updateChrome();
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request';
    }
  });

  goTo(0);
</script>
